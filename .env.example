# --- OpenAI (Beat 2 cloud stream) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
# Shorter cloud answers; stricter cap reduces rambling (raise for long explanations)
OPENAI_MAX_TOKENS=512
OPENAI_CLOUD_TEMPERATURE=0.15

# --- Ollama (Beat 2 local stream) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# --- Service ports ---
PY_PORT=8001
NODE_PORT=3000
FRONTEND_PORT=3000

# --- Demo guard rails (Decision 5 hard cap) ---
MAX_INPUT_BYTES=10240
